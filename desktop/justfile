set windows-shell := ["cmd.exe", "/c"]

mod release

# Show available commands
default:
    @just --list

# Build the project
build:
    {{ ninja }} pylib qt

# Build wheels (needed for some platforms)
wheels:
    {{ ninja }} wheels

# Build and run all checks (lint + test) - lets ninja handle dependencies
check:
    {{ ninja }} pylib qt check

# Run all tests (Rust, Python, TypeScript)
test:
    {{ ninja }} check:rust_test check:pytest check:vitest

# Check formatting (fast, no build needed)
fmt:
    {{ ninja }} check:format

# Fix formatting
fix-fmt:
    {{ ninja }} format

# Run linting and type checking (requires build outputs)
lint:
    {{ ninja }} \
        check:clippy \
        check:mypy \
        check:ruff \
        check:eslint \
        check:svelte \
        check:typescript

# Fix auto-fixable lint issues (ruff + eslint)
fix-lint:
    {{ ninja }} fix:ruff fix:eslint

# Run minilints (copyright, contributors, licenses)
minilints:
    {{ ninja }} check:minilints

# Fix minilints (update licenses.json)
fix-minilints:
    {{ ninja }} fix:minilints

# Sync translation files
ftl-sync:
    {{ ninja }} ftl-sync

# Deprecate translation strings
ftl-deprecate:
    {{ ninja }} ftl-deprecate

# Speedrun: one-command 50,000-card benchmark vs the §10 targets (challenge 7h)
bench *ARGS:
    {{ ninja }} pylib
    PYTHONPATH=out/pylib out/pyenv/bin/python tools/speedrun/bench.py {{ ARGS }}

# Speedrun: SIGKILL-mid-review crash test + network-off AI check (challenge 7g)
crash-test *ARGS:
    {{ ninja }} pylib
    PYTHONPATH=out/pylib out/pyenv/bin/python tools/speedrun/crash_test.py {{ ARGS }}

# Speedrun: two-client offline sync + conflict-rule proof (challenge 7b)
sync-test *ARGS:
    {{ ninja }} pylib
    PYTHONPATH=out/pylib out/pyenv/bin/python tools/speedrun/sync_test.py {{ ARGS }}

# Speedrun: FSRS memory calibration on held-out reviews (§9 Step 1)
memory-calibration *ARGS:
    {{ ninja }} pylib
    PYTHONPATH=out/pylib out/pyenv/bin/python tools/speedrun/memory_calibration.py {{ ARGS }}

# Speedrun: gold-set card checker + one-source generated batch (challenge 7f)
card-check *ARGS:
    python3 tools/speedrun/card_check.py {{ ARGS }}

# Speedrun: prompt-injection resistance across every model-facing surface (§10 hidden-text)
injection-eval *ARGS:
    python3 tools/speedrun/injection_eval.py {{ ARGS }}

# Speedrun: probe bank validation + leakage scan + self-test; --collection for the real bridge/calibration (7d/7e)
probe-harness *ARGS:
    python3 tools/speedrun/probe_harness.py {{ ARGS }}

# Speedrun: simulation ablation; --collection for the real-data observational companion (§8)
ablation *ARGS:
    python3 tools/speedrun/ablation.py {{ ARGS }}

# Speedrun: run the offline tooling test suite
speedrun-test:
    python3 -m unittest discover -s tools/speedrun/tests

# Build documentation site
docs:
    uv run --group docs sphinx-build -b html docs out/docs/html
    @echo "Docs built at out/docs/html/index.html"

# Build and serve documentation site
docs-serve:
    uv run --group docs sphinx-autobuild docs out/docs/html --host 127.0.0.1 --port 8000

# Build Rust API docs
docs-rust:
    cargo doc --open

# Dispatch CI workflow on a given branch or tag
ci branch:
    gh workflow run ci.yml --ref {{ branch }}

# Helper to get the right ninja command for the platform
ninja := if os() == "windows" { "tools\\ninja" } else { "./ninja" }
